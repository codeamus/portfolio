---
import Navbar from "@components/Navbar.astro";
import Layout from "@layouts/Layout.astro";
import HeroV2 from "@components/HeroV2.astro";
import Services from "@components/Services.astro";
import Projects from "@components/Projects.astro";
import About from "@components/About.astro";
import Footer from "@components/Footer.astro";
import HowWork from "@components/HowWork.astro";
import Faq from "@components/Faq.astro";
import ContactForm from "@components/ContactForm.astro";
import SchemaMarkup from "@components/SchemaMarkup.astro";

// Import scroll animations script
import "@scripts/scroll-animations";
---

<Layout
  title="Desarrollo Web y Apps Móviles | CODEAMUS - Santiago, Chile"
  description="Agencia freelance especializada en desarrollo web con Astro y aplicaciones móviles iOS/Android. Proyectos profesionales con animaciones impactantes y SEO optimizado."
>
  <Navbar />
  <main>
    <HeroV2 />
    <Services />
    <Projects />
    <HowWork id="como-trabajo" />
    <Faq />
    <ContactForm />
    <About />
  </main>
  <Footer />
</Layout>

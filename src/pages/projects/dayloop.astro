---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";

const projects = await getCollection("projects");
const project = projects.find((p) => p.slug === "dayloop");

if (!project) {
  return new Response("Proyecto no encontrado", { status: 404 });
}

const { data, body } = project;
const {
  title,
  description,
  website,
  appStore,
  googlePlay,
  technologies,
  metrics,
  image_desktop,
} = data;

const metaTitle = data.metaTitle || `${title} | CODEAMUS`;
const metaDescription =
  data.metaDescription ||
  description;
---

<Layout title={metaTitle} description={metaDescription}>
  <section class="min-h-screen bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] px-6 py-20 md:px-12 xl:px-72">
    <!-- Back Button -->
    <a
      href="/#proyectos"
      class="inline-flex items-center gap-2 text-[#5b5bff] hover:text-white transition-colors mb-12"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"
        />
      </svg>
      Volver a proyectos
    </a>

    <!-- Header -->
    <div class="mb-16">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">{title}</h1>
      <p class="text-xl text-white/70 max-w-3xl leading-relaxed mb-8">
        {description}
      </p>

      <!-- Tech Stack -->
      {technologies && technologies.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {technologies.map((tech) => (
            <span class="inline-block px-3 py-1 bg-[#5b5bff]/20 text-[#5b5bff] rounded-full text-sm font-medium border border-[#5b5bff]/30">
              {tech}
            </span>
          ))}
        </div>
      )}

      <!-- Metrics -->
      {metrics && (
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-8 p-6 bg-white/5 rounded-xl border border-white/10">
          {metrics.downloads && (
            <div>
              <p class="text-white/60 text-sm mb-2">Descargas</p>
              <p class="text-2xl font-bold text-white">{metrics.downloads}</p>
            </div>
          )}
          {metrics.rating && (
            <div>
              <p class="text-white/60 text-sm mb-2">Calificación</p>
              <p class="text-2xl font-bold text-white">{metrics.rating}</p>
            </div>
          )}
          {metrics.reviews && (
            <div>
              <p class="text-white/60 text-sm mb-2">Plataformas</p>
              <p class="text-2xl font-bold text-white">{metrics.reviews}</p>
            </div>
          )}
        </div>
      )}

      <!-- CTA Buttons -->
      <div class="flex flex-wrap gap-4">
        {website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] transition-all duration-300"
          >
            🌐 Visitar sitio web
          </a>
        )}
        {appStore && appStore !== "coming-soon" && (
          <a
            href={appStore}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all duration-300"
          >
            📱 App Store
          </a>
        )}
        {googlePlay && googlePlay !== "coming-soon" && (
          <a
            href={googlePlay}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all duration-300"
          >
            📱 Google Play
          </a>
        )}
      </div>
    </div>

    <!-- Hero Image -->
    {image_desktop && (
      <div class="mb-20 rounded-2xl overflow-hidden border border-white/10">
        <img
          src={image_desktop}
          alt={`${title} - Vista principal`}
          class="w-full h-auto object-cover"
          loading="lazy"
        />
      </div>
    )}

    <!-- Content -->
    <div class="prose prose-invert max-w-none mb-20">
      <article set:html={body} />
    </div>

    <!-- Related Projects CTA -->
    <div class="text-center py-16 border-t border-white/10">
      <p class="text-white/60 mb-6">¿Te gustaría contar tu proyecto?</p>
      <a
        href="/#contacto"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 transition-all duration-300"
      >
        Solicitar presupuesto
      </a>
    </div>
  </section>
</Layout>

<style is:global>
  .prose {
    --prose-body: rgb(255 255 255 / 0.7);
    --prose-headings: rgb(255 255 255);
    --prose-lead: rgb(255 255 255 / 0.6);
    --prose-links: rgb(91 91 255);
    --prose-strong: rgb(255 255 255);
    --prose-code: rgb(91 91 255);
    --prose-hr: rgb(255 255 255 / 0.1);
  }

  .prose strong {
    color: rgb(255 255 255);
  }

  .prose a {
    color: rgb(91 91 255);
    text-decoration: underline;
    transition: color 0.3s;
  }

  .prose a:hover {
    color: rgb(255 255 255);
  }

  .prose p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
  }

  .prose h2 {
    margin-top: 2em;
    margin-bottom: 1em;
    font-size: 2em;
  }

  .prose h3 {
    margin-top: 1.5em;
    margin-bottom: 0.5em;
    font-size: 1.5em;
  }

  .prose ul,
  .prose ol {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.625em;
  }

  .prose li {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }

  .prose code {
    background-color: rgb(91 91 255 / 0.1);
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    color: rgb(91 91 255);
  }

  .prose pre {
    background-color: rgb(15 23 42 / 0.8);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 0.5em;
    padding: 1em;
    overflow-x: auto;
  }
</style>

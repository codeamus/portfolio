---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";

const projects = await getCollection("projects");
const project = projects.find((p) => p.slug === "dayloop");

if (!project) {
  return new Response("Proyecto no encontrado", { status: 404 });
}

const { data, body } = project;
const {
  title,
  description,
  website,
  appStore,
  googlePlay,
  technologies,
  metrics,
  image_desktop,
  image_mobile,
} = data;

const metaTitle = data.metaTitle || `${title} | CODEAMUS`;
const metaDescription =
  data.metaDescription ||
  description;
---

<Layout title={metaTitle} description={metaDescription}>
  <section class="bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] min-h-screen">
    <!-- Back Button -->
    <div class="px-6 py-8 md:px-12 xl:px-72">
      <a
        href="/#proyectos"
        class="inline-flex items-center gap-2 text-[#5b5bff] hover:text-white transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"
          />
        </svg>
        Volver a proyectos
      </a>
    </div>

    <!-- Hero Header -->
    <div class="px-6 py-12 md:px-12 xl:px-72 border-b border-white/10">
      <div class="max-w-2xl">
        <p class="text-[#5b5bff] text-sm font-semibold uppercase tracking-widest mb-4">
          Caso de estudio
        </p>
        <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">{title}</h1>
        <p class="text-xl text-white/70 leading-relaxed mb-8">{description}</p>

        <!-- Tech Stack -->
        {technologies && technologies.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-8">
            {technologies.slice(0, 6).map((tech) => (
              <span class="inline-block px-2.5 py-1 bg-[#5b5bff]/20 text-[#5b5bff] rounded-full text-xs font-medium border border-[#5b5bff]/30">
                {tech}
              </span>
            ))}
          </div>
        )}

        <!-- Metrics -->
        {metrics && (
          <div class="grid grid-cols-3 gap-6 p-6 bg-white/5 rounded-lg border border-white/10 mb-8">
            {metrics.downloads && (
              <div>
                <p class="text-white/60 text-xs mb-2 uppercase tracking-wide">Descargas</p>
                <p class="text-2xl font-bold text-white">{metrics.downloads}</p>
              </div>
            )}
            {metrics.rating && (
              <div>
                <p class="text-white/60 text-xs mb-2 uppercase tracking-wide">Rating</p>
                <p class="text-2xl font-bold text-white">{metrics.rating}</p>
              </div>
            )}
            {metrics.reviews && (
              <div>
                <p class="text-white/60 text-xs mb-2 uppercase tracking-wide">Plataformas</p>
                <p class="text-2xl font-bold text-white">{metrics.reviews}</p>
              </div>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Web & App Section -->
    <div class="px-6 py-16 md:px-12 xl:px-72">
      <div class="grid md:grid-cols-2 gap-12 mb-20">
        <!-- Web Section -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">🌐 Sitio Web</h2>
          {image_desktop && (
            <div class="mb-6 rounded-xl overflow-hidden border border-white/10 hover:border-[#5b5bff]/50 transition-all duration-300">
              <img
                src={image_desktop}
                alt={`${title} - Web Desktop`}
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          )}
          {website && (
            <a
              href={website}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-semibold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] transition-all duration-300 w-full justify-center"
            >
              Visitar sitio web →
            </a>
          )}
        </div>

        <!-- Mobile / App Section -->
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">📱 Aplicación Móvil</h2>
          {image_mobile && (
            <div class="mb-6 rounded-xl overflow-hidden border border-white/10">
              <img
                src={image_mobile}
                alt={`${title} - App Mobile`}
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          )}
          <div class="flex gap-3">
            {appStore && appStore !== "coming-soon" && (
              <a
                href={appStore}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all duration-300"
              >
                App Store
              </a>
            )}
            {googlePlay && googlePlay !== "coming-soon" && (
              <a
                href={googlePlay}
                target="_blank"
                rel="noopener noreferrer"
                class="flex-1 inline-flex items-center justify-center gap-2 px-4 py-3 bg-white/10 text-white font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all duration-300"
              >
                Google Play
              </a>
            )}
          </div>
        </div>
      </div>

      <!-- Content -->
      <div class="py-16 border-t border-white/10">
        <div class="prose prose-invert max-w-none">
          <article set:html={body} />
        </div>
      </div>

      <!-- CTA Footer -->
      <div class="text-center py-16 border-t border-white/10">
        <h3 class="text-3xl font-bold text-white mb-4">¿Te gustaría contar tu proyecto?</h3>
        <p class="text-white/60 mb-8 max-w-2xl mx-auto">
          Conversemos sobre tu idea. Podemos ayudarte a construir algo extraordinario.
        </p>
        <a
          href="/#contacto"
          class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 transition-all duration-300"
        >
          Solicitar presupuesto →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .prose {
    --prose-body: rgb(255 255 255 / 0.7);
    --prose-headings: rgb(255 255 255);
    --prose-lead: rgb(255 255 255 / 0.6);
    --prose-links: rgb(91 91 255);
    --prose-strong: rgb(255 255 255);
    --prose-code: rgb(91 91 255);
    --prose-hr: rgb(255 255 255 / 0.1);
  }

  .prose strong {
    color: rgb(255 255 255);
  }

  .prose a {
    color: rgb(91 91 255);
    text-decoration: underline;
    transition: color 0.3s;
  }

  .prose a:hover {
    color: rgb(255 255 255);
  }

  .prose p {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    line-height: 1.75;
  }

  .prose h2 {
    margin-top: 2em;
    margin-bottom: 1em;
    font-size: 1.875em;
    font-weight: 700;
  }

  .prose h3 {
    margin-top: 1.5em;
    margin-bottom: 0.75em;
    font-size: 1.5em;
    font-weight: 600;
  }

  .prose ul,
  .prose ol {
    margin-top: 1.25em;
    margin-bottom: 1.25em;
    padding-left: 1.625em;
  }

  .prose li {
    margin-top: 0.5em;
    margin-bottom: 0.5em;
  }

  .prose code {
    background-color: rgb(91 91 255 / 0.1);
    padding: 0.2em 0.4em;
    border-radius: 0.25em;
    color: rgb(91 91 255);
    font-size: 0.9em;
  }

  .prose pre {
    background-color: rgb(15 23 42 / 0.8);
    border: 1px solid rgb(255 255 255 / 0.1);
    border-radius: 0.5em;
    padding: 1.5em;
    overflow-x: auto;
    line-height: 1.5;
  }

  .prose blockquote {
    border-left: 4px solid rgb(91 91 255);
    padding-left: 1em;
    color: rgb(255 255 255 / 0.8);
    font-style: italic;
  }
</style>

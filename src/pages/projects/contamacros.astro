---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";

const projects = await getCollection("projects");
const project = projects.find((p: any) => p.slug === "contamacros" || p.id === "contamacros");

if (!project) {
  return new Response("Proyecto no encontrado", { status: 404 });
}

const { data } = project;
const {
  title,
  description,
  website,
  appStore,
  googlePlay,
  technologies,
  appScreenshots,
  image_desktop,
} = data;

const metaTitle = data.metaTitle || `${title} | CODEAMUS`;
const metaDescription = data.metaDescription || description;

const features = [
  {
    icon: "🔍",
    title: "Escaneo Inteligente",
    desc: "Escanea códigos de barras con integración OpenFoodFacts para reconocimiento nutricional instantáneo.",
  },
  {
    icon: "🍽️",
    title: "IA para Platos",
    desc: "Toma una foto de tu plato y la IA identifica ingredientes. Entrenada especialmente en platos chilenos.",
  },
  {
    icon: "🏋️",
    title: "Fitness Coach Pro",
    desc: "Coach conversacional personalizado con recomendaciones según tu objetivo y seguimiento de streaks.",
  },
  {
    icon: "📊",
    title: "Sincronización Health",
    desc: "Integración con Apple Health (iOS) y Health Connect (Android) de forma automática.",
  },
];

const stack = [
  { category: "Frontend", items: ["React Native", "Expo Router", "TypeScript"] },
  { category: "Backend", items: ["Supabase", "PostgreSQL", "RLS Auth"] },
  { category: "APIs", items: ["OpenFoodFacts", "OpenAI Vision"] },
  { category: "DevOps", items: ["Expo Build", "Expo Submit", "OTA Updates"] },
];
---

<Layout title={metaTitle} description={metaDescription}>

  <!-- ─── BANNER HERO ─── -->
  <section class="relative w-full h-[60vh] min-h-[420px] overflow-hidden">
    <img
      src={image_desktop}
      alt={title}
      class="w-full h-full object-cover object-top"
    />
    <!-- gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-[#0f172a] via-[#0f172a]/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-[#0f172a]/80 via-transparent to-transparent"></div>

    <!-- Back button -->
    <a
      href="/#proyectos"
      class="absolute top-8 left-6 md:left-12 xl:left-72 inline-flex items-center gap-2 text-white/80 hover:text-white transition-colors duration-300 text-sm font-medium backdrop-blur-sm bg-white/10 px-4 py-2 rounded-full border border-white/20"
    >
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
      </svg>
      Volver
    </a>

    <!-- Hero content over banner -->
    <div class="absolute bottom-0 left-0 right-0 px-6 pb-12 md:px-12 xl:px-72">
      <span class="text-[#5b5bff] text-xs font-bold uppercase tracking-[0.2em] mb-3 block">Caso de Estudio</span>
      <h1 class="text-5xl md:text-6xl font-black text-white mb-3 leading-tight">{title}</h1>
      <p class="text-white/70 text-base max-w-xl leading-relaxed mb-6">{description}</p>

      <div class="flex gap-3 flex-wrap">
        {website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="px-6 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-xl text-sm hover:shadow-[0_10px_40px_rgba(91,91,255,0.4)] transition-all duration-300 hover:scale-105"
          >
            Visitar sitio →
          </a>
        )}
        {appStore && appStore !== "coming-soon" && (
          <a href={appStore} target="_blank" rel="noopener noreferrer"
            class="px-6 py-3 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl text-sm border border-white/20 hover:bg-white/20 transition-all duration-300">
            App Store
          </a>
        )}
        {googlePlay && googlePlay !== "coming-soon" && (
          <a href={googlePlay} target="_blank" rel="noopener noreferrer"
            class="px-6 py-3 bg-white/10 backdrop-blur-sm text-white font-semibold rounded-xl text-sm border border-white/20 hover:bg-white/20 transition-all duration-300">
            Google Play
          </a>
        )}
      </div>
    </div>
  </section>

  <!-- ─── TECH BADGES + CONTEXTO ─── -->
  <section class="px-6 py-12 md:px-12 xl:px-72 border-b border-white/10">
    <div class="flex flex-col md:flex-row md:items-center gap-6">
      <div class="flex-1">
        <p class="text-white/50 text-xs font-semibold uppercase tracking-widest mb-3">Stack tecnológico</p>
        <div class="flex flex-wrap gap-2">
          {technologies && technologies.map((tech: any) => (
            <span class="px-3 py-1.5 bg-[#5b5bff]/10 text-[#8b8bff] rounded-lg text-xs font-semibold border border-[#5b5bff]/20 uppercase tracking-wide">
              {tech}
            </span>
          ))}
        </div>
      </div>
      <div class="flex gap-8 text-center">
        <div>
          <p class="text-2xl font-black text-white">Web</p>
          <p class="text-white/50 text-xs">+ App Móvil</p>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <p class="text-2xl font-black text-white">IA</p>
          <p class="text-white/50 text-xs">OpenAI Vision</p>
        </div>
        <div class="w-px bg-white/10"></div>
        <div>
          <p class="text-2xl font-black text-white">CL</p>
          <p class="text-white/50 text-xs">Mercado chileno</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── EL PROBLEMA ─── -->
  <section class="px-6 py-16 md:px-12 xl:px-72">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-[#5b5bff] text-xs font-bold uppercase tracking-[0.2em] mb-4">El Problema</p>
        <h2 class="text-3xl font-black text-white mb-4 leading-tight">Contar calorías era aburrido y complicado</h2>
        <p class="text-white/70 text-sm leading-relaxed">
          Los usuarios abandonaban las apps de nutrición porque no estaban pensadas para el mercado chileno, pedían demasiado esfuerzo manual y no personalizaban las recomendaciones.
        </p>
      </div>
      <div class="flex flex-col gap-3">
        {[
          "Escribir alimentos manualmente es tedioso",
          "Sin platos chilenos en la base de datos",
          "Sin recomendaciones según objetivos personales",
        ].map((pain) => (
          <div class="flex items-start gap-3 p-4 bg-red-500/5 border border-red-500/15 rounded-xl">
            <span class="text-red-400 mt-0.5 flex-shrink-0">✕</span>
            <p class="text-white/80 text-sm">{pain}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── FEATURES CARDS ─── -->
  <section class="px-6 py-16 md:px-12 xl:px-72 border-t border-white/10">
    <div class="mb-10">
      <p class="text-[#5b5bff] text-xs font-bold uppercase tracking-[0.2em] mb-3">La Solución</p>
      <h2 class="text-3xl font-black text-white">4 features que lo cambian todo</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {features.map((f) => (
        <div class="group p-6 bg-white/4 hover:bg-white/8 border border-white/10 hover:border-[#5b5bff]/40 rounded-2xl transition-all duration-300 cursor-default">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="text-white font-bold text-sm mb-2">{f.title}</h3>
          <p class="text-white/60 text-xs leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── STACK TÉCNICO ─── -->
  <section class="px-6 py-16 md:px-12 xl:px-72 border-t border-white/10">
    <div class="mb-10">
      <p class="text-[#5b5bff] text-xs font-bold uppercase tracking-[0.2em] mb-3">Arquitectura</p>
      <h2 class="text-3xl font-black text-white">Stack Técnico</h2>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {stack.map((s) => (
        <div class="p-5 bg-white/4 border border-white/10 rounded-2xl">
          <p class="text-[#5b5bff] text-xs font-bold uppercase tracking-widest mb-3">{s.category}</p>
          <ul class="flex flex-col gap-2">
            {s.items.map((item) => (
              <li class="flex items-center gap-2 text-white/80 text-sm">
                <span class="w-1.5 h-1.5 bg-[#5b5bff] rounded-full flex-shrink-0"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- ─── SCREENSHOTS CAROUSEL ─── -->
  {appScreenshots && appScreenshots.length > 0 && (
    <section class="py-16 border-t border-white/10">
      <div class="px-6 md:px-12 xl:px-72 mb-8">
        <p class="text-[#5b5bff] text-xs font-bold uppercase tracking-[0.2em] mb-3">Galería</p>
        <h2 class="text-3xl font-black text-white">Pantallas de la App</h2>
      </div>
      <div class="px-6 md:px-12 xl:px-72 overflow-x-auto scrollbar-hide">
        <div class="flex gap-5 pb-4" style="width: max-content;">
          {appScreenshots.map((screenshot: any, index: number) => (
            <div class="flex-shrink-0 w-64 group">
              <div class="relative h-[520px] rounded-2xl overflow-hidden border border-white/10 hover:border-[#5b5bff]/50 transition-all duration-500 shadow-xl hover:shadow-[0_20px_50px_rgba(91,91,255,0.2)]">
                <img
                  src={screenshot}
                  alt={`Pantalla ${index + 1}`}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="px-6 md:px-12 xl:px-72 mt-4">
        <p class="text-white/40 text-xs">← Desliza para explorar →</p>
      </div>
    </section>
  )}

  <!-- ─── CTA ─── -->
  <section class="px-6 py-20 md:px-12 xl:px-72 border-t border-white/10">
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8 p-8 md:p-12 bg-gradient-to-r from-[#5b5bff]/10 to-[#6366f1]/10 border border-[#5b5bff]/20 rounded-2xl">
      <div>
        <h3 class="text-2xl md:text-3xl font-black text-white mb-2">¿Listo para tu proyecto?</h3>
        <p class="text-white/60 text-sm">Cuéntanos tu idea y construimos algo extraordinario juntos.</p>
      </div>
      <a
        href="/#contacto"
        class="flex-shrink-0 px-8 py-4 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-xl text-sm hover:shadow-[0_10px_40px_rgba(91,91,255,0.4)] transition-all duration-300 hover:scale-105 text-center"
      >
        Solicitar presupuesto →
      </a>
    </div>
  </section>

</Layout>

<style is:global>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

---
// Services Component - Taste-Skill Premium Edition
// Motion Intensity: HIGH
// Visual Density: LOW
import { WHATSAPP_URL } from "@utils/const";

const SERVICES = [
  {
    icon: "🌐",
    name: "Landing Pages",
    description: "Páginas de conversión optimizadas para captar clientes",
    priceMin: "$100.000",
    priceMax: "$200.000",
    features: [
      "Single page con scroll",
      "Diseño moderno y responsivo",
      "Optimizado para conversiones",
      "Formulario de contacto",
      "SEO técnico básico",
    ],
    deliveryTime: "5-7 días",
    cta: "Empezar",
    highlight: true,
  },
  {
    icon: "🏢",
    name: "Sitios Web + E-commerce",
    description: "Webs completos con múltiples secciones, tiendas online y funcionalidades avanzadas",
    priceMin: "$300.000",
    priceMax: "$600.000",
    features: [
      "5-15 páginas personalizadas",
      "Blog, portafolio o tienda online",
      "Diseño consistente y profesional",
      "SEO técnico avanzado",
      "Admin panel para gestionar contenido",
    ],
    deliveryTime: "2-3 semanas",
    cta: "Cotizar",
  },
  {
    icon: "📱",
    name: "Apps Móviles",
    description: "Aplicaciones iOS y Android con React Native + Expo",
    priceMin: "$2.000.000",
    priceMax: "$5.000.000",
    features: [
      "iOS + Android (una codebase)",
      "Interfaz moderna y fluida",
      "Integración con APIs",
      "QA incluido",
      "Publicación en App Store y Play Store",
    ],
    deliveryTime: "3-5 semanas",
    cta: "Consultar",
  },
];
---

<section
  id="servicios"
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] px-6 py-24 md:px-12 lg:px-20 xl:px-32 overflow-hidden"
>
  <!-- Background Glow -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />
  <div class="absolute -right-40 bottom-20 h-80 w-80 rounded-full bg-[#6366f1]/5 blur-3xl" />

  <div class="relative z-10 max-w-6xl mx-auto">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center mb-16">
      <p data-reveal="up" class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Soluciones para cada necesidad
      </p>
      <h2 data-reveal="up" data-reveal-delay="100" class="text-4xl md:text-5xl font-bold text-white mb-6">
        Servicios Especializados
      </h2>
      <p data-reveal="up" data-reveal-delay="200" class="text-base md:text-lg text-white/70 leading-relaxed">
        Desde landing pages rápidas hasta aplicaciones móviles complejas. Todo
        con enfoque en resultados y velocidad.
      </p>
    </div>

    <!-- Services Grid -->
    <div class="grid gap-6 grid-cols-1 md:grid-cols-3">
      {
        SERVICES.map((service, index) => (
          <article
            data-reveal="up"
            data-reveal-delay={`${index * 150}`}
            class={`group relative rounded-2xl border transition-all duration-300 flex flex-col ${
              service.highlight
                ? 'border-[#5b5bff]/50 bg-gradient-to-br from-[#5b5bff]/10 to-transparent shadow-[0_0_20px_rgba(91,91,255,0.15)]'
                : 'border-white/10 bg-white/5'
            } p-6 hover:border-[#5b5bff]/40 hover:shadow-[0_0_24px_rgba(91,91,255,0.12)] service-card`}
          >
            {service.highlight && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] px-4 py-1 rounded-full text-[10px] font-bold text-white uppercase tracking-wider whitespace-nowrap">
                Popular
              </div>
            )}

            {/* Icon + Title */}
            <div class="flex items-center gap-3 mb-3">
              <div class="flex items-center justify-center w-11 h-11 rounded-xl bg-gradient-to-br from-[#5b5bff]/20 to-[#6366f1]/10 border border-[#5b5bff]/30 group-hover:from-[#5b5bff]/30 group-hover:to-[#6366f1]/20 transition-all duration-300 flex-shrink-0">
                <span class="text-lg">{service.icon}</span>
              </div>
              <h3 class="text-lg font-bold text-white">
                {service.name}
              </h3>
            </div>

            {/* Description */}
            <p class="text-sm text-white/65 leading-relaxed mb-5">
              {service.description}
            </p>

            {/* Price Section */}
            <div class="mb-5 p-4 rounded-lg bg-[#5b5bff]/5 border border-[#5b5bff]/20">
              <p class="text-xs text-white/60 uppercase tracking-wide font-semibold mb-2">Precio desde</p>
              <div class="flex items-baseline gap-2">
                <span class="text-2xl font-bold text-[#5b5bff]">{service.priceMin}</span>
                <span class="text-xs text-white/50">hasta {service.priceMax}</span>
              </div>
            </div>

            {/* Features */}
            <ul class="space-y-2 mb-5 flex-grow">
              {service.features.map((feature) => (
                <li class="flex gap-2 items-start">
                  <span class="text-[#5b5bff] text-xs mt-0.5">✓</span>
                  <span class="text-white/75 text-sm">{feature}</span>
                </li>
              ))}
            </ul>

            {/* Delivery Time */}
            <div class="inline-flex items-center gap-1.5 bg-[#5b5bff]/10 rounded-lg px-3 py-1.5 text-xs font-medium text-[#5b5bff] mb-5 border border-[#5b5bff]/20 self-start">
              <span>⏱</span> Entrega: {service.deliveryTime}
            </div>

            {/* CTA Button */}
            <a
              href={WHATSAPP_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="block w-full mt-auto bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold py-2.5 px-5 rounded-lg text-center text-sm transition-all duration-300 hover:shadow-[0_0_20px_rgba(91,91,255,0.4)] hover:scale-[1.02] btn-ripple"
            >
              {service.cta}
            </a>
          </article>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div data-reveal="up" class="mt-16 text-center">
      <p class="text-white/60 mb-5 text-base">
        ¿No sabes cuál necesitas? Hablemos de tu proyecto.
      </p>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-7 py-2.5 rounded-lg border border-white/20 text-white font-semibold text-sm hover:border-[#5b5bff] hover:bg-[#5b5bff]/10 transition-all duration-300"
      >
        Solicitar Consulta
      </a>
    </div>
  </div>
</section>

<style>
  .service-card {
    transition: all 0.3s ease;
  }

  .service-card:hover {
    transform: translateY(-4px);
  }
</style>

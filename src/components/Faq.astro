---
// FAQ Accordion - Taste-Skill Premium Edition
// Motion Intensity: HIGH
const FAQS = [
  {
    id: 1,
    question: "¿Cuánto se demora en estar listo mi sitio?",
    answer:
      "Depende del plan y qué tan rápido tengas el contenido, pero una landing rápida suele estar lista entre 3 y 5 días hábiles. Un sitio multi-sección puede ir entre 5 y 10 días.",
  },
  {
    id: 2,
    question: "¿Qué necesito tener listo antes de empezar?",
    answer:
      "Idealmente: logo, colores de marca (si tienes), textos base sobre tu negocio y servicios, y algunas fotos. Si no tienes todo, igual podemos partir y yo te guío en qué preparar.",
  },
  {
    id: 3,
    question: "¿Incluye dominio y hosting?",
    answer:
      "El valor de los planes es solo por el diseño y desarrollo del sitio. El dominio y el hosting los contratas tú, pero te puedo orientar en qué proveedor elegir y cómo hacerlo.",
  },
  {
    id: 4,
    question: "¿Puedo pedir cambios después de la entrega?",
    answer:
      "Sí. Incluyo una ronda de ajustes razonables después de la entrega inicial. Si necesitas cambios frecuentes, lo ideal es el plan de mantención mensual.",
  },
  {
    id: 5,
    question: "¿Puedo pagar en cuotas o con tarjeta?",
    answer:
      "Podemos ver opciones según el proyecto. Habitualmente trabajo con pagos por transferencia y, en proyectos más grandes, con un porcentaje inicial y otro a la entrega.",
  },
];
---

<section
  id="faq"
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] px-10 py-24 md:px-20 xl:px-72 overflow-hidden"
>
  <!-- Background Glow -->
  <div class="absolute -right-40 top-20 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />

  <div class="relative z-10">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center mb-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Dudas frecuentes
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Preguntas frecuentes
      </h2>
      <p class="text-base md:text-lg text-white/70">
        Las dudas más comunes resueltas. ¿Tienes otra pregunta? Escríbeme directo por WhatsApp.
      </p>
    </div>

    <!-- FAQ Accordion -->
    <div class="mx-auto max-w-3xl space-y-4">
      {
        FAQS.map((item, index) => (
          <details
            class="group rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm hover:border-[#5b5bff]/30 transition-colors duration-300 cursor-pointer overflow-hidden"
            id={`faq-${item.id}`}
          >
            <summary class="flex items-center justify-between gap-4 px-6 md:px-8 py-5 md:py-6 select-none">
              <!-- Question -->
              <h3 class="text-base md:text-lg font-semibold text-white/90 group-hover:text-white transition-colors duration-300">
                {item.question}
              </h3>

              <!-- Icon -->
              <div class="flex items-center justify-center w-8 h-8 rounded-full bg-[#5b5bff]/10 group-hover:bg-[#5b5bff]/20 transition-all duration-300 flex-shrink-0">
                <svg
                  class="w-5 h-5 text-[#5b5bff] transition-transform duration-300 group-open:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 14l-7 7m0 0l-7-7m7 7V3"
                  />
                </svg>
              </div>
            </summary>

            <!-- Answer -->
            <div class="border-t border-white/10 px-6 md:px-8 py-5 md:py-6 bg-gradient-to-b from-[#5b5bff]/5 to-transparent">
              <p class="text-sm md:text-base text-white/75 leading-relaxed">
                {item.answer}
              </p>
            </div>
          </details>
        ))
      }
    </div>

    <!-- CTA -->
    <div class="mt-16 text-center">
      <p class="text-white/60 mb-6">
        ¿Necesitas más información personalizada?
      </p>
      <a
        href="https://wa.me/56985284259?text=Hola%20Matías,%20tengo%20una%20pregunta%20sobre%20mi%20proyecto"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3 rounded-lg border-2 border-[#5b5bff] text-[#5b5bff] font-semibold hover:bg-[#5b5bff]/10 transition-all duration-300"
      >
        💬 Pregúntame por WhatsApp
      </a>
    </div>
  </div>
</section>

<style>
  details {
    transition: all var(--animation-duration-base) var(--animation-easing-smooth);
  }

  details[open] {
    border-color: rgba(91, 91, 255, 0.3);
    box-shadow: 0 0 20px rgba(91, 91, 255, 0.1);
  }

  summary::-webkit-details-marker {
    display: none;
  }

  summary {
    list-style: none;
  }
</style>

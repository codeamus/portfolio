---
// Projects Portfolio - Taste-Skill Premium Edition
// Motion Intensity: HIGH
import IconWebSite from "@assets/icons/world.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
---

<section
  id="proyectos"
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0a0f1f] to-[#0f172a] px-10 py-24 md:px-20 xl:px-72 overflow-hidden"
>
  <!-- Background Glow -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />

  <div class="relative z-10">
    <!-- ENCABEZADO -->
    <header class="mb-20">
      <p data-reveal="up" class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Casos de éxito
      </p>
      <h2 data-reveal="up" data-reveal-delay="100" class="text-4xl md:text-5xl font-bold text-white mb-6">
        Proyectos realizados
      </h2>
      <p data-reveal="up" data-reveal-delay="200" class="text-base md:text-lg text-white/70 max-w-3xl leading-relaxed">
        Sitios web y aplicaciones que he construido para clientes reales.
        Cada proyecto fue diseñado con enfoque en conversión, velocidad y
        experiencia del usuario.
      </p>
    </header>

    <!-- LISTA DE PROYECTOS -->
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2">
      {
        projects.map((project, index) => {
          const { data } = project;
          const {
            title,
            description,
            image_desktop,
            image_mobile,
            website,
            appStore,
            googlePlay,
            slug,
            type,
            technologies,
            metrics,
          } = data;

          const projectUrl = `/projects/${slug}`;
          const ariaTitle = `Visitar el sitio web de ${title}`;
          const isApp = type === "app" || type === "fullstack";

          return (
            <article
              data-reveal="up"
              data-reveal-delay={`${index * 200}`}
              class="group relative flex flex-col rounded-2xl border border-white/10 bg-white/[0.03] overflow-hidden transition-all duration-500 hover:border-[#5b5bff]/40 hover:shadow-[0_20px_60px_rgba(91,91,255,0.12)] hover:-translate-y-2"
            >
              {/* Image Container */}
              <div class="relative overflow-hidden">
                <a href={projectUrl} class="block">
                  <picture>
                    <source srcset={image_desktop} media="(min-width: 1024px)" />
                    <img
                      transition:name={`img-${slug}`}
                      src={image_mobile}
                      alt={`Vista del sitio web ${title}`}
                      class="w-full aspect-[16/10] object-cover brightness-[0.85] group-hover:brightness-100 group-hover:scale-105 transition-all duration-700 ease-out"
                      loading="lazy"
                    />
                  </picture>
                </a>

                {/* Gradient overlay */}
                <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f1f] via-transparent to-transparent opacity-60" />

                {/* Live badge */}
                {website && (
                  <a
                    href={website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="absolute top-4 right-4 inline-flex items-center gap-1.5 bg-black/50 backdrop-blur-md border border-white/10 text-white/90 text-xs font-medium px-3 py-1.5 rounded-full hover:bg-[#5b5bff]/30 hover:border-[#5b5bff]/50 transition-all duration-300"
                  >
                    <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse" />
                    Live
                  </a>
                )}
              </div>

              {/* Content */}
              <div class="flex flex-col flex-grow p-6 md:p-8">
                <h3 class="text-xl md:text-2xl font-bold text-white mb-3 group-hover:text-[#5b5bff] transition-colors duration-300">
                  {title}
                </h3>

                <p class="text-white/60 text-sm md:text-base leading-relaxed mb-4 flex-grow">
                  {description}
                </p>

                {/* Technologies */}
                {technologies && technologies.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-6">
                    {technologies.slice(0, 3).map((tech) => (
                      <span class="inline-block text-xs font-medium px-2 py-1 bg-[#5b5bff]/10 text-[#5b5bff] rounded-full border border-[#5b5bff]/20">
                        {tech}
                      </span>
                    ))}
                    {technologies.length > 3 && (
                      <span class="inline-block text-xs font-medium px-2 py-1 bg-white/5 text-white/60 rounded-full border border-white/10">
                        +{technologies.length - 3}
                      </span>
                    )}
                  </div>
                )}

                {/* Actions */}
                <div class="flex flex-wrap items-center gap-2 pt-4 border-t border-white/[0.06]">
                  <a
                    href={projectUrl}
                    class="inline-flex items-center gap-2 text-sm font-semibold text-[#5b5bff] hover:text-white transition-colors duration-300 group/link"
                  >
                    Ver caso
                    <svg class="w-4 h-4 group-hover/link:translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>

                  {website && (
                    <a
                      href={website}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={ariaTitle}
                      class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-xs font-medium px-2 py-1 rounded transition-colors duration-300 border border-white/10 hover:border-white/20"
                    >
                      <IconWebSite className="size-3.5" />
                      Web
                    </a>
                  )}

                  {appStore && appStore !== "coming-soon" && (
                    <a
                      href={appStore}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Descargar ${title} en App Store`}
                      class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-xs font-medium px-2 py-1 rounded transition-colors duration-300 border border-white/10 hover:border-white/20"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M17.05 13.5c-.05 1.6.85 3 2.45 3.2-.35 1.05-1.15 2.05-2.15 2.6-.95.5-1.95.55-2.55.3-.4-.15-.8-.15-1.25 0-.65.25-1.65.2-2.55-.3-1.05-.6-1.9-1.55-2.25-2.6 1.6-.2 2.55-1.6 2.5-3.2-.1-1.7-1.2-3.15-2.75-3.5 1.25-1 3.2-.95 4.85.4 1.65-.75 3.55-.75 5.2.2 1.45.9 2.55 2.35 2.6 4.1zm-8.3 4.5c.6.95 1.95 1.45 3.2 1.45 1.3 0 2.65-.55 3.25-1.45 1.15-.05 2.2-.5 3.05-1.25-.75 2.4-2.95 4.2-5.45 4.2-2.45 0-4.65-1.8-5.4-4.2.85.75 1.9 1.2 3.05 1.25z" />
                      </svg>
                      App Store
                    </a>
                  )}

                  {googlePlay && googlePlay !== "coming-soon" && (
                    <a
                      href={googlePlay}
                      target="_blank"
                      rel="noopener noreferrer"
                      aria-label={`Descargar ${title} en Google Play`}
                      class="inline-flex items-center gap-1.5 text-white/60 hover:text-white text-xs font-medium px-2 py-1 rounded transition-colors duration-300 border border-white/10 hover:border-white/20"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M3.609 1.814L13.792 12 3.609 22.186V1.814M4.5 1L14.5 11.5 4.5 23l9.5-10.5 6.5-1.5L14 12l6-1.5-6-1.5L4.5 1z" />
                      </svg>
                      Play
                    </a>
                  )}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <!-- Bottom CTA -->
    <div data-reveal="up" class="mt-20 text-center">
      <p class="text-white/60 mb-6">
        ¿Te gustaría contar tu proyecto? Hablemos sobre tu idea.
      </p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 transition-all duration-300 btn-ripple"
      >
        Solicitar presupuesto
      </a>
    </div>
  </div>
</section>

<style>
  .btn-ripple {
    position: relative;
    overflow: hidden;
  }

  .btn-ripple::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .btn-ripple:active::after {
    width: 300px;
    height: 300px;
  }
</style>

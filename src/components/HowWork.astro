---
// How Work - Taste-Skill Premium Edition
// Motion Intensity: HIGH
// Visual Density: LOW
interface Props {
  id?: string;
}

const { id = "como-trabajo" } = Astro.props;

const STEPS = [
  {
    number: "01",
    icon: "💬",
    title: "Me cuentas tu idea",
    description:
      "Hablamos por WhatsApp o videollamada. Me explicas de qué trata tu negocio y qué esperas del sitio.",
  },
  {
    number: "02",
    icon: "📋",
    title: "Estructura y contenido",
    description:
      "Te propongo una estructura y te digo qué textos e imágenes necesito para comenzar el desarrollo.",
  },
  {
    number: "03",
    icon: "🎨",
    title: "Diseño y desarrollo",
    description:
      "Diseño y desarrollo tu sitio. Te muestro avances para mantener transparencia en el proceso.",
  },
  {
    number: "04",
    icon: "✅",
    title: "Revisión y ajustes",
    description:
      "Revisamos juntos el resultado y hacemos ajustes razonables hasta que estés satisfecho.",
  },
  {
    number: "05",
    icon: "🚀",
    title: "Publicación y soporte",
    description:
      "Publicamos tu sitio. Te oriento en cómo usarlo y ofrezco soporte inicial o mantención mensual.",
  },
];
---

<section
  {id}
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0a0f1f] to-[#0f172a] px-10 py-24 md:px-20 xl:px-72 overflow-hidden"
>
  <!-- Background Glows -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />
  <div class="absolute -right-40 bottom-20 h-80 w-80 rounded-full bg-[#6366f1]/5 blur-3xl" />

  <div class="relative z-10">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center mb-20">
      <p data-reveal="up" class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Proceso transparente
      </p>
      <h2 data-reveal="up" data-reveal-delay="100" class="text-4xl md:text-5xl font-bold text-white mb-6">
        Cómo trabajamos juntos
      </h2>
      <p data-reveal="up" data-reveal-delay="200" class="text-base md:text-lg text-white/70">
        Un proceso claro, transparente y sin complicaciones. Tú me cuentas qué necesitas, yo me encargo del resto.
      </p>
    </div>

    <!-- Steps: Row 1 (3 cards) -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
      {
        STEPS.slice(0, 3).map((step, index) => (
          <div
            class="group relative"
            data-reveal="up"
            data-reveal-delay={`${index * 120}`}
          >
            <article class="step-card rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 hover:border-[#5b5bff]/30 hover:shadow-[0_0_20px_rgba(91,91,255,0.1)] transition-all duration-300 h-full flex flex-col">
              {/* Header: Number + Icon */}
              <div class="flex items-center gap-4 mb-4">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-br from-[#5b5bff]/20 to-[#6366f1]/10 border border-[#5b5bff]/30 group-hover:from-[#5b5bff]/30 group-hover:to-[#6366f1]/20 transition-all duration-300 flex-shrink-0">
                  <span class="text-xl">{step.icon}</span>
                </div>
                <span class="text-xs font-bold text-[#5b5bff]/60 tracking-widest">PASO {step.number}</span>
              </div>

              {/* Content */}
              <h3 class="text-lg font-bold text-white mb-2">
                {step.title}
              </h3>
              <p class="text-sm text-white/65 leading-relaxed">
                {step.description}
              </p>
            </article>
          </div>
        ))
      }
    </div>

    <!-- Steps: Row 2 (2 cards, centered) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto">
      {
        STEPS.slice(3).map((step, index) => (
          <div
            class="group relative"
            data-reveal="up"
            data-reveal-delay={`${(index + 3) * 120}`}
          >
            <article class="step-card rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 hover:border-[#5b5bff]/30 hover:shadow-[0_0_20px_rgba(91,91,255,0.1)] transition-all duration-300 h-full flex flex-col">
              {/* Header: Number + Icon */}
              <div class="flex items-center gap-4 mb-4">
                <div class="flex items-center justify-center w-12 h-12 rounded-full bg-gradient-to-br from-[#5b5bff]/20 to-[#6366f1]/10 border border-[#5b5bff]/30 group-hover:from-[#5b5bff]/30 group-hover:to-[#6366f1]/20 transition-all duration-300 flex-shrink-0">
                  <span class="text-xl">{step.icon}</span>
                </div>
                <span class="text-xs font-bold text-[#5b5bff]/60 tracking-widest">PASO {step.number}</span>
              </div>

              {/* Content */}
              <h3 class="text-lg font-bold text-white mb-2">
                {step.title}
              </h3>
              <p class="text-sm text-white/65 leading-relaxed">
                {step.description}
              </p>
            </article>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div data-reveal="up" class="mt-20 text-center">
      <p class="text-white/60 mb-6 text-lg">
        ¿Listo para comenzar tu proyecto?
      </p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 transition-all duration-300 btn-ripple"
      >
        Empecemos hoy 🚀
      </a>
    </div>
  </div>
</section>

<style>
  .step-card {
    transition: all 0.3s ease;
  }

  .step-card:hover {
    transform: translateY(-4px);
  }

  .btn-ripple {
    position: relative;
    overflow: hidden;
  }

  .btn-ripple::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .btn-ripple:active::after {
    width: 300px;
    height: 300px;
  }
</style>

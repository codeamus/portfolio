---
// How Work - Taste-Skill Premium Edition
// Motion Intensity: HIGH
// Visual Density: LOW
interface Props {
  id?: string;
}

const { id = "como-trabajo" } = Astro.props;

const STEPS = [
  {
    number: "01",
    icon: "💬",
    title: "Me cuentas tu idea",
    description:
      "Hablamos por WhatsApp o videollamada. Me explicas de qué trata tu negocio y qué esperas del sitio.",
  },
  {
    number: "02",
    icon: "📋",
    title: "Estructura y contenido",
    description:
      "Te propongo una estructura y te digo qué textos e imágenes necesito para comenzar el desarrollo.",
  },
  {
    number: "03",
    icon: "🎨",
    title: "Diseño y desarrollo",
    description:
      "Diseño y desarrollo tu sitio. Te muestro avances para mantener transparencia en el proceso.",
  },
  {
    number: "04",
    icon: "✅",
    title: "Revisión y ajustes",
    description:
      "Revisamos juntos el resultado y hacemos ajustes razonables hasta que estés satisfecho.",
  },
  {
    number: "05",
    icon: "🚀",
    title: "Publicación y soporte",
    description:
      "Publicamos tu sitio. Te oriento en cómo usarlo y ofrezco soporte inicial o mantención mensual.",
  },
];
---

<section
  {id}
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0a0f1f] to-[#0f172a] px-10 py-24 md:px-20 xl:px-72 overflow-hidden"
>
  <!-- Background Glows -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />
  <div class="absolute -right-40 bottom-20 h-80 w-80 rounded-full bg-[#6366f1]/5 blur-3xl" />

  <div class="relative z-10">
    <!-- Header -->
    <div class="mx-auto max-w-3xl text-center mb-20">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Proceso transparente
      </p>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">
        Cómo trabajamos juntos
      </h2>
      <p class="text-base md:text-lg text-white/70">
        Un proceso claro, transparente y sin complicaciones. Tú me cuentas qué necesitas, yo me encargo del resto.
      </p>
    </div>

    <!-- Steps Container -->
    <div class="relative">
      <!-- Connection Line (visible on desktop) -->
      <div class="hidden lg:block absolute top-24 left-0 right-0 h-1 bg-gradient-to-r from-[#5b5bff]/0 via-[#5b5bff]/20 to-[#5b5bff]/0" />

      <!-- Steps Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
        {
          STEPS.map((step, index) => (
            <div
              class="group relative"
              style={{ '--stagger-index': index } as any}
            >
              <!-- Step Card -->
              <article class="rounded-2xl border border-white/10 bg-white/5 backdrop-blur-sm p-6 md:p-8 hover:border-[#5b5bff]/30 hover:shadow-[0_0_20px_rgba(91,91,255,0.1)] transition-all duration-300 card-premium h-full flex flex-col">
                {/* Icon Circle */}
                <div class="flex items-center justify-center w-16 h-16 md:w-20 md:h-20 rounded-full bg-gradient-to-br from-[#5b5bff]/20 to-[#6366f1]/10 border border-[#5b5bff]/30 mb-6 group-hover:from-[#5b5bff]/30 group-hover:to-[#6366f1]/20 transition-all duration-300">
                  <span class="text-2xl md:text-3xl">{step.icon}</span>
                </div>

                {/* Number Badge */}
                <div class="absolute top-4 right-4 flex items-center justify-center w-10 h-10 rounded-full bg-[#5b5bff]/10 border border-[#5b5bff]/30 text-xs font-bold text-[#5b5bff] group-hover:bg-[#5b5bff]/20 transition-all duration-300">
                  {step.number}
                </div>

                {/* Content */}
                <div class="flex-grow">
                  <h3 class="text-lg md:text-xl font-bold text-white mb-3 pr-8">
                    {step.title}
                  </h3>
                  <p class="text-sm md:text-base text-white/70 leading-relaxed">
                    {step.description}
                  </p>
                </div>

                {/* Arrow (desktop only) */}
                {index < STEPS.length - 1 && (
                  <div class="hidden lg:flex absolute -right-3 top-1/2 -translate-y-1/2 text-[#5b5bff]/30 group-hover:text-[#5b5bff]/60 transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                  </div>
                )}
              </article>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Bottom CTA -->
    <div class="mt-20 text-center">
      <p class="text-white/60 mb-6 text-lg">
        ¿Listo para comenzar tu proyecto?
      </p>
      <a
        href="#contacto"
        class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 transition-all duration-300 btn-ripple"
      >
        Empecemos hoy 🚀
      </a>
    </div>
  </div>
</section>

<style>
  .card-premium {
    transition: all var(--animation-duration-base) var(--animation-easing-smooth);
  }

  .card-premium:hover {
    transform: translateY(-4px);
  }

  .btn-ripple {
    position: relative;
    overflow: hidden;
  }

  .btn-ripple::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .btn-ripple:active::after {
    width: 300px;
    height: 300px;
  }
</style>

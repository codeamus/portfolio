---
// Servicios Especializados - CODEAMUS Pricing
// Componente de precios optimizado para freelancer
---

<section id="servicios" class="relative border-t border-white/10 bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] px-6 sm:px-8 py-24 md:px-20 xl:px-40">
  <!-- Background Glow -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />
  <div class="absolute -right-40 bottom-20 h-80 w-80 rounded-full bg-[#6366f1]/5 blur-3xl" />

  <div class="relative z-10 max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-20">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Servicios Especializados
      </p>
      <h2 class="text-5xl md:text-6xl font-bold text-white mb-6" style="font-family: 'Pacifico', cursive;">
        Nuestros Servicios
      </h2>
      <p class="text-lg text-white/70 max-w-2xl mx-auto">
        Desarrollo web y apps móviles con entrega rápida, calidad premium y precios competitivos.
      </p>
    </div>

    <!-- Pricing Cards Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">

      <!-- Card 1: Landing Pages -->
      <div class="group rounded-2xl border border-white/10 bg-white/5 p-8 md:p-10 backdrop-blur-sm hover:border-[#5b5bff]/50 transition-all duration-300 hover:shadow-2xl hover:shadow-[#5b5bff]/10 hover:translate-y-[-4px]">
        <div class="mb-6">
          <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-[#5b5bff] to-[#6366f1] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Landing Pages</h3>
          <p class="text-white/60 text-sm">Páginas de captura y validación rápidas</p>
        </div>

        <div class="mb-6 space-y-4">
          <div class="p-4 rounded-lg bg-white/5 border border-white/10">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Rango de precio</p>
            <p class="text-3xl font-bold text-[#5b5bff]">$100K - $200K</p>
            <p class="text-xs text-white/50 mt-1">CLP</p>
          </div>

          <div class="p-4 rounded-lg bg-white/5 border border-white/10">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Entrega</p>
            <p class="text-lg font-bold text-white">5-10 días</p>
          </div>
        </div>

        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Single page responsive</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Formulario de contacto</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">SEO técnico básico</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Dominio + hosting 1 año</span>
          </li>
        </ul>

        <button class="w-full bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#5b5bff]/50 hover:scale-105">
          Consultar
        </button>
      </div>

      <!-- Card 2: Sitios Web -->
      <div class="group rounded-2xl border border-[#5b5bff]/30 bg-gradient-to-br from-white/10 to-white/5 p-8 md:p-10 backdrop-blur-sm hover:border-[#5b5bff]/70 transition-all duration-300 hover:shadow-2xl hover:shadow-[#5b5bff]/20 hover:translate-y-[-4px] ring-1 ring-[#5b5bff]/20">
        <div class="absolute top-4 right-4 bg-[#5b5bff] text-white text-xs font-bold px-3 py-1 rounded-full">
          POPULAR
        </div>

        <div class="mb-6">
          <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-[#5b5bff] to-[#6366f1] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21H3V3h18v18zm-9-10h.01M12 17v-5m5-5H7" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Sitios Web</h3>
          <p class="text-white/60 text-sm">Profesionales con múltiples páginas</p>
        </div>

        <div class="mb-6 space-y-4">
          <div class="p-4 rounded-lg bg-white/5 border border-[#5b5bff]/30">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Rango de precio</p>
            <p class="text-3xl font-bold text-[#5b5bff]">$300K - $600K</p>
            <p class="text-xs text-white/50 mt-1">CLP</p>
          </div>

          <div class="p-4 rounded-lg bg-white/5 border border-[#5b5bff]/30">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Entrega</p>
            <p class="text-lg font-bold text-white">2-3 semanas</p>
          </div>
        </div>

        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">5-12 páginas</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Blog integrado</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">SEO avanzado</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">CRM + Email marketing</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Opción e-commerce</span>
          </li>
        </ul>

        <button class="w-full bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#5b5bff]/50 hover:scale-105">
          Consultar
        </button>
      </div>

      <!-- Card 3: Apps Móviles -->
      <div class="group rounded-2xl border border-white/10 bg-white/5 p-8 md:p-10 backdrop-blur-sm hover:border-[#5b5bff]/50 transition-all duration-300 hover:shadow-2xl hover:shadow-[#5b5bff]/10 hover:translate-y-[-4px]">
        <div class="mb-6">
          <div class="w-14 h-14 rounded-lg bg-gradient-to-br from-[#5b5bff] to-[#6366f1] flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-white mb-2">Apps Móviles</h3>
          <p class="text-white/60 text-sm">React Native con Expo</p>
        </div>

        <div class="mb-6 space-y-4">
          <div class="p-4 rounded-lg bg-white/5 border border-white/10">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Rango de precio</p>
            <p class="text-3xl font-bold text-[#5b5bff]">$2M - $8M</p>
            <p class="text-xs text-white/50 mt-1">CLP</p>
          </div>

          <div class="p-4 rounded-lg bg-white/5 border border-white/10">
            <p class="text-xs font-semibold text-white/70 uppercase mb-1">Entrega</p>
            <p class="text-lg font-bold text-white">3-5 semanas</p>
          </div>
        </div>

        <ul class="space-y-3 mb-8">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">iOS + Android simultáneamente</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">5-12 pantallas</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">Autenticación avanzada</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-[#5b5bff] mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-white/80">API integrations</span>
          </li>
        </ul>

        <button class="w-full bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#5b5bff]/50 hover:scale-105">
          Consultar
        </button>
      </div>

    </div>

    <!-- Tabla Comparativa -->
    <div class="mt-20 pt-20 border-t border-white/10">
      <h3 class="text-3xl font-bold text-white text-center mb-12">Comparación Rápida</h3>

      <div class="overflow-x-auto">
        <table class="w-full text-white">
          <thead>
            <tr class="border-b border-white/10">
              <th class="text-left py-4 px-4 font-bold text-white/70">Característica</th>
              <th class="text-center py-4 px-4 font-bold">Landing Page</th>
              <th class="text-center py-4 px-4 font-bold">Sitio Web</th>
              <th class="text-center py-4 px-4 font-bold">App Móvil</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Precio</td>
              <td class="text-center py-4 px-4 text-[#5b5bff] font-bold">$100K-$200K</td>
              <td class="text-center py-4 px-4 text-[#5b5bff] font-bold">$300K-$600K</td>
              <td class="text-center py-4 px-4 text-[#5b5bff] font-bold">$2M-$8M</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Entrega</td>
              <td class="text-center py-4 px-4">5-10 días</td>
              <td class="text-center py-4 px-4">2-3 semanas</td>
              <td class="text-center py-4 px-4">3-5 semanas</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Páginas/Pantallas</td>
              <td class="text-center py-4 px-4">1</td>
              <td class="text-center py-4 px-4">5-12</td>
              <td class="text-center py-4 px-4">5-12</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">SEO</td>
              <td class="text-center py-4 px-4">Básico</td>
              <td class="text-center py-4 px-4">Avanzado</td>
              <td class="text-center py-4 px-4">Analytics</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Plataformas</td>
              <td class="text-center py-4 px-4">Web</td>
              <td class="text-center py-4 px-4">Web</td>
              <td class="text-center py-4 px-4">iOS + Android</td>
            </tr>
            <tr class="border-b border-white/5 hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Dominio + Hosting</td>
              <td class="text-center py-4 px-4">✓ 1 año</td>
              <td class="text-center py-4 px-4">✓ 1 año</td>
              <td class="text-center py-4 px-4">✓ Incluido</td>
            </tr>
            <tr class="hover:bg-white/5 transition-colors">
              <td class="py-4 px-4 text-white/70">Soporte</td>
              <td class="text-center py-4 px-4">1 mes</td>
              <td class="text-center py-4 px-4">1 mes</td>
              <td class="text-center py-4 px-4">1 mes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- CTA Final -->
    <div class="mt-20 text-center">
      <p class="text-white/70 mb-8 text-lg">¿No estás seguro cuál es la mejor opción para ti?</p>
      <a
        href="/#contacto"
        class="inline-block px-8 py-4 bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold rounded-lg transition-all duration-300 hover:shadow-lg hover:shadow-[#5b5bff]/50 hover:scale-105"
      >
        Agenda una consulta gratuita
      </a>
    </div>
  </div>
</section>

<style>
  table {
    width: 100%;
  }

  th, td {
    padding: 1rem;
  }

  tr:hover {
    background-color: rgba(255, 255, 255, 0.05);
  }
</style>

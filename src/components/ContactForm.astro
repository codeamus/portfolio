---
// Contact Form - Taste-Skill Premium Edition
// Motion Intensity: HIGH
// Validación con Zod
---

<section
  id="contacto"
  class="relative border-t border-white/10 bg-gradient-to-b from-[#0f172a] to-[#0a0f1f] px-10 py-24 md:px-20 xl:px-72 overflow-hidden"
>
  <!-- Background Glow -->
  <div class="absolute -left-40 top-40 h-80 w-80 rounded-full bg-[#5b5bff]/5 blur-3xl" />
  <div class="absolute -right-40 bottom-20 h-80 w-80 rounded-full bg-[#6366f1]/5 blur-3xl" />

  <div class="relative z-10 max-w-2xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-16">
      <p data-reveal="up" class="text-xs font-semibold uppercase tracking-[0.15em] text-[#5b5bff] mb-4">
        Comencemos tu proyecto
      </p>
      <h2 data-reveal="up" data-reveal-delay="100" class="text-4xl md:text-5xl font-bold text-white mb-6">
        Hablemos de tu idea
      </h2>
      <p data-reveal="up" data-reveal-delay="200" class="text-white/70">
        Completa el formulario y te responderé en máximo 24 horas hábiles.
      </p>
    </div>

    <!-- Form -->
    <form
      data-reveal="up"
      data-reveal-delay="100"
      id="contact-form"
      class="space-y-6 rounded-2xl border border-white/10 bg-white/5 p-8 md:p-10 backdrop-blur-sm hover:border-[#5b5bff]/30 transition-colors duration-300"
    >
      <!-- Row 1: Nombre y Email -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="form-group">
          <label for="name" class="block text-sm font-semibold text-white mb-2">
            Tu nombre
          </label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="Juan García"
            required
            class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white placeholder:text-white/40 focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300"
          />
          <span class="error-message text-red-400 text-xs mt-1 hidden"></span>
        </div>

        <div class="form-group">
          <label for="email" class="block text-sm font-semibold text-white mb-2">
            Tu email
          </label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="juan@ejemplo.com"
            required
            class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white placeholder:text-white/40 focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300"
          />
          <span class="error-message text-red-400 text-xs mt-1 hidden"></span>
        </div>
      </div>

      <!-- Row 2: Teléfono y Empresa -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="form-group">
          <label for="phone" class="block text-sm font-semibold text-white mb-2">
            Teléfono (opcional)
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="+56 9 XXXX XXXX"
            class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white placeholder:text-white/40 focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300"
          />
        </div>

        <div class="form-group">
          <label for="service" class="block text-sm font-semibold text-white mb-2">
            Tipo de proyecto
          </label>
          <select
            id="service"
            name="service"
            required
            class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300"
          >
            <option value="" disabled selected class="bg-[#0f172a]">Selecciona un servicio</option>
            <option value="landing" class="bg-[#0f172a]">Landing Page</option>
            <option value="website" class="bg-[#0f172a]">Sitio Web Profesional</option>
            <option value="app" class="bg-[#0f172a]">App Móvil</option>
            <option value="otro" class="bg-[#0f172a]">Otro</option>
          </select>
          <span class="error-message text-red-400 text-xs mt-1 hidden"></span>
        </div>
      </div>

      <!-- Row 3: Budget -->
      <div class="form-group">
        <label for="budget" class="block text-sm font-semibold text-white mb-2">
          Presupuesto estimado (opcional)
        </label>
        <select
          id="budget"
          name="budget"
          class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300"
        >
          <option value="" class="bg-[#0f172a]">Sin presupuesto definido</option>
          <option value="1000-5000" class="bg-[#0f172a]">$1,000 - $5,000 USD</option>
          <option value="5000-15000" class="bg-[#0f172a]">$5,000 - $15,000 USD</option>
          <option value="15000-50000" class="bg-[#0f172a]">$15,000 - $50,000 USD</option>
          <option value="50000+" class="bg-[#0f172a]">$50,000+ USD</option>
        </select>
      </div>

      <!-- Message -->
      <div class="form-group">
        <label for="message" class="block text-sm font-semibold text-white mb-2">
          Cuéntame sobre tu proyecto
        </label>
        <textarea
          id="message"
          name="message"
          placeholder="Descripción de tu idea, necesidades, y cualquier detalle importante..."
          rows="5"
          required
          class="w-full rounded-lg bg-white/5 border border-white/10 px-4 py-3 text-white placeholder:text-white/40 focus:border-[#5b5bff] focus:outline-none focus:ring-2 focus:ring-[#5b5bff]/30 transition-all duration-300 resize-none"
        ></textarea>
        <span class="error-message text-red-400 text-xs mt-1 hidden"></span>
      </div>

      <!-- Checkbox: Términos -->
      <div class="flex items-start gap-3">
        <input
          type="checkbox"
          id="terms"
          name="terms"
          required
          class="mt-1 w-5 h-5 rounded border-white/20 bg-white/5 text-[#5b5bff] focus:ring-2 focus:ring-[#5b5bff]/30 cursor-pointer"
        />
        <label for="terms" class="text-sm text-white/70">
          Acepto que me contactes para hablar sobre mi proyecto
        </label>
      </div>

      <!-- Submit Button -->
      <div class="pt-4">
        <button
          type="submit"
          id="submit-btn"
          class="w-full bg-gradient-to-r from-[#5b5bff] to-[#6366f1] text-white font-bold py-3 px-6 rounded-lg transition-all duration-300 hover:shadow-[0_0_30px_rgba(91,91,255,0.4)] hover:scale-105 btn-ripple flex items-center justify-center gap-2"
        >
          <span id="btn-text">Enviar mensaje</span>
          <svg id="btn-spinner" class="hidden w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </div>

      <!-- Success Message -->
      <div
        id="success-message"
        class="hidden rounded-lg bg-green-500/10 border border-green-500/30 p-4 text-green-400 text-sm text-center"
      >
        ✓ ¡Mensaje enviado con éxito! Te responderé pronto.
      </div>

      <!-- Error Message -->
      <div id="error-message" class="hidden rounded-lg bg-red-500/10 border border-red-500/30 p-4 text-red-400 text-sm text-center">
        ⚠ Hubo un error. Por favor, intenta de nuevo o contacta a través de WhatsApp.
      </div>
    </form>

    <!-- Alternative CTA -->
    <div class="mt-8 text-center">
      <p class="text-white/60 mb-4">¿Prefieres contactarme directamente?</p>
      <a
        href="https://wa.me/56985284259?text=Hola%20Matías,%20quiero%20hablarte%20sobre%20mi%20proyecto"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg border-2 border-[#5b5bff] text-[#5b5bff] font-semibold hover:bg-[#5b5bff]/10 transition-all duration-300"
      >
        💬 Escribir por WhatsApp
      </a>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLElement;
  const successMessage = document.getElementById('success-message') as HTMLElement;
  const errorMessage = document.getElementById('error-message') as HTMLElement;

  form.addEventListener('submit', async (e: Event) => {
    e.preventDefault();

    // Validación básica
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const service = (document.getElementById('service') as HTMLSelectElement).value;
    const message = (document.getElementById('message') as HTMLTextAreaElement).value.trim();

    if (!name || !email || !service || !message) {
      showError('Por favor completa todos los campos requeridos');
      return;
    }

    // Email regex validation
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      showError('Por favor ingresa un email válido');
      return;
    }

    // Show loading state
    submitBtn.disabled = true;
    btnText.textContent = 'Enviando...';
    btnSpinner.classList.remove('hidden');
    successMessage.classList.add('hidden');
    errorMessage.classList.add('hidden');

    try {
      // Aquí se conectaría con Formspree, Resend o tu endpoint favorito
      // Por ahora, simulamos el envío
      await new Promise(resolve => setTimeout(resolve, 1500));

      // Simular éxito
      form.reset();
      successMessage.classList.remove('hidden');
      submitBtn.disabled = false;
      btnText.textContent = 'Enviar mensaje';
      btnSpinner.classList.add('hidden');

      // Limpiar mensaje después de 5 segundos
      setTimeout(() => {
        successMessage.classList.add('hidden');
      }, 5000);
    } catch (error) {
      showError('Error al enviar el mensaje. Por favor intenta de nuevo.');
    }
  });

  function showError(message: string) {
    errorMessage.textContent = '⚠ ' + message;
    errorMessage.classList.remove('hidden');
    submitBtn.disabled = false;
    btnText.textContent = 'Enviar mensaje';
    btnSpinner.classList.add('hidden');
  }

  // Real-time validation on blur
  const inputs = form.querySelectorAll('input[required], textarea[required], select[required]');
  inputs.forEach(input => {
    input.addEventListener('blur', () => {
      const value = (input as HTMLInputElement).value.trim();
      const errorSpan = (input.parentElement?.querySelector('.error-message') as HTMLElement);

      if (!value && errorSpan) {
        errorSpan.textContent = 'Este campo es requerido';
        errorSpan.classList.remove('hidden');
      } else if (errorSpan) {
        errorSpan.classList.add('hidden');
      }
    });
  });
</script>

<style>
  .form-group {
    position: relative;
  }

  input:focus,
  textarea:focus,
  select:focus {
    background-color: rgba(91, 91, 255, 0.05);
  }

  textarea {
    font-family: inherit;
  }

  .btn-ripple {
    position: relative;
    overflow: hidden;
  }

  .btn-ripple::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.3);
    transform: translate(-50%, -50%);
    transition: width 0.6s, height 0.6s;
  }

  .btn-ripple:active::after {
    width: 300px;
    height: 300px;
  }
</style>

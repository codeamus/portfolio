      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Los costos varían según el tipo de app. Apps simples: $5,000-$8,000. Apps medianas: $15,000-$25,000. Apps complejas: $25,000+. Depende del alcance, features y plataforma."
      }
    },
    {
      "@type": "Question",
      "name": "¿Cuál es tu stack tecnológico?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Usamos Astro + React para web, y React Native / Flutter para apps móviles. Tailwind CSS para estilos y bases de datos modernas."
      }
    },
    {
      "@type": "Question",
      "name": "¿Haces SEO?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí, incluimos SEO técnico en todos los proyectos: Core Web Vitals optimizados, meta tags, schema markup, y structure data."
      }
    }
  ]
};
